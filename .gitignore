# public/build/  ← committed because you use vite
# node_modules/  ← still ignored, not needed on server
/node_modules
/.phpunit.cache

# Docker (at project root level)
# docker-compose.yml  ← NOT ignored, needed on server
# Dockerfile          ← NOT ignored, needed on server
*.bundle
