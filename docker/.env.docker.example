APP_NAME="Your App Name"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://your-domain.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql                   # must match container name in docker-compose
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=laravel
DB_PASSWORD=

# ─── Broadcasting / Cache / Queue / Session ───────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
CACHE_STORE=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── Memcached ────────────────────────────────────────────
MEMCACHED_HOST=127.0.0.1

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=redis                # must match container name in docker-compose
REDIS_PASSWORD=null
REDIS_PORT=6379
